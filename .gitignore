# Environment & secrets
.env

# Data directories (large files)
data/
scenarios/
logs/

# Results (keep summary files, ignore per-fit JSONs)
results/*
!results/summary_metrics.csv
!results/summary_run_d_pristat.csv
!results/summary_run_e_fft.csv
!results/summary_run_f_umap13d.csv
!results/best_params.json
!results/best_params_run_d_pristat.json
!results/best_params_run_e_fft.json
!results/best_params_run_f_umap13d.json
!results/run_comparison.csv

# Experiment 2 results (keep summaries, ignore per-window JSONs)
results_experiment2/*
!results_experiment2/summary_umap_hdbscan.csv
!results_experiment2/summary_gmm.csv
!results_experiment2/final_comparison_4way.csv

# Run B backup (keep summaries, ignore per-window JSONs)
results_runB_backup/*
!results_runB_backup/best_params.json
!results_runB_backup/summary_metrics.csv

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter
.ipynb_checkpoints/
*.ipynb

# IDE
.vscode/
.idea/
*.swp
*.swo

